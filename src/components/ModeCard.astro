---
interface Props {
  mode: 'brainstorm' | 'execute' | 'refine';
  title: string;
  description: string;
  color: string;
  badge?: string;
  disabled?: boolean;
  disabledReason?: string;
}

const { mode, title, description, color, badge, disabled = false, disabledReason } = Astro.props;
const href = disabled ? undefined : `/session/new?mode=${mode}`;
---

{disabled ? (
  <div class="card disabled" style={`--accent: ${color}`}>
    <div class="indicator" />
    <h2>{title}</h2>
    <p>{description}</p>
    {disabledReason && <p class="reason">{disabledReason}</p>}
  </div>
) : (
  <a href={href} class="card" style={`--accent: ${color}`}>
    <div class="indicator" />
    <div class="card-title-row">
      <h2>{title}</h2>
      {badge && <span class="badge">{badge}</span>}
    </div>
    <p>{description}</p>
  </a>
)}

<style>
  .card {
    display: block;
    padding: 1.5rem;
    border: 1px solid #e5e5e5;
    border-radius: 0.75rem;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
    position: relative;
    overflow: hidden;
  }

  .card:hover:not(.disabled) {
    border-color: var(--accent);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .card.disabled {
    opacity: 0.55;
    cursor: default;
  }

  .indicator {
    width: 2.5rem;
    height: 0.25rem;
    background: var(--accent);
    border-radius: 1rem;
    margin-bottom: 1rem;
  }

  .card-title-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-size: 1.125rem;
    font-weight: 600;
  }

  .badge {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
    background: #e8f5e9;
    color: #2e7d32;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  p {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.5;
  }

  .reason {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    font-style: italic;
    color: #999;
  }
</style>
