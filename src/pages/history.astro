---
import AppShell from '../layouts/AppShell.astro';
---

<AppShell title="History">
  <div class="history">
    <div class="history-header">
      <h1>Session History</h1>
      <div class="filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="brainstorm">Brainstorm</button>
        <button class="filter-btn" data-filter="execute">Execute</button>
        <button class="filter-btn" data-filter="refine">Refine</button>
      </div>
    </div>

    <input type="search" id="search" class="search" placeholder="Search sessions..." />

    <div id="session-list" class="session-list">
      <p class="empty-state" id="empty-state">Loading sessions...</p>
    </div>
  </div>

  <style>
    .history {
      max-width: 48rem;
      margin: 0 auto;
    }

    .history-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    h1 {
      font-size: 1.5rem;
      font-weight: 700;
    }

    .filters {
      display: flex;
      gap: 0.5rem;
    }

    .filter-btn {
      padding: 0.3rem 0.75rem;
      border: 1px solid #ddd;
      border-radius: 1rem;
      background: #fff;
      font-size: 0.8rem;
      cursor: pointer;
      transition: all 0.15s;
    }

    .filter-btn:hover {
      border-color: #888;
    }

    .filter-btn.active {
      background: #1a1a1a;
      color: #fff;
      border-color: #1a1a1a;
    }

    .search {
      width: 100%;
      padding: 0.6rem 0.75rem;
      border: 1px solid #ddd;
      border-radius: 0.5rem;
      font-family: inherit;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .search:focus {
      outline: none;
      border-color: #888;
    }

    .session-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .session-card {
      display: block;
      padding: 1rem 1.25rem;
      background: #fff;
      border: 1px solid #e5e5e5;
      border-radius: 0.75rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s;
    }

    .session-card:hover {
      border-color: #888;
    }

    .session-card-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.5rem;
    }

    .session-mode {
      font-size: 0.7rem;
      font-weight: 600;
      padding: 0.15rem 0.5rem;
      border-radius: 1rem;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .session-date {
      font-size: 0.8rem;
      color: #999;
    }

    .session-outcome {
      margin-left: auto;
      font-size: 0.75rem;
      font-weight: 500;
    }

    .session-outcome.yes { color: #059669; }
    .session-outcome.partially { color: #d97706; }
    .session-outcome.no { color: #dc2626; }

    .session-preview {
      font-size: 0.85rem;
      color: #666;
      line-height: 1.4;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .session-cost {
      font-size: 0.75rem;
      color: #999;
      margin-top: 0.25rem;
    }

    .empty-state {
      text-align: center;
      color: #999;
      padding: 3rem 1rem;
    }

    .empty-state a {
      color: #2563eb;
    }
  </style>

  <script>
    import { listSessions } from '../lib/session-store';
    import type { Session, Mode } from '../lib/types';

    const modeColors: Record<Mode, string> = {
      brainstorm: '#2563eb',
      execute: '#059669',
      refine: '#9333ea',
    };

    const outcomeLabels: Record<string, string> = {
      yes: 'Success',
      partially: 'Partial',
      no: 'Missed',
    };

    let allSessions: Session[] = [];
    let currentFilter = 'all';
    let searchQuery = '';

    const listEl = document.getElementById('session-list')!;
    const emptyEl = document.getElementById('empty-state')!;
    const searchInput = document.getElementById('search') as HTMLInputElement;

    function renderSessions() {
      let filtered = allSessions;

      if (currentFilter !== 'all') {
        filtered = filtered.filter((s) => s.mode === currentFilter);
      }

      if (searchQuery) {
        const q = searchQuery.toLowerCase();
        filtered = filtered.filter(
          (s) =>
            s.shapedPrompt.toLowerCase().includes(q) ||
            s.conversation.some((m) => m.content.toLowerCase().includes(q)),
        );
      }

      listEl.innerHTML = '';

      if (filtered.length === 0) {
        emptyEl.innerHTML =
          allSessions.length === 0
            ? 'No sessions yet — <a href="/">start one!</a>'
            : 'No sessions match your search.';
        emptyEl.style.display = 'block';
        return;
      }

      emptyEl.style.display = 'none';

      filtered.forEach((session) => {
        const card = document.createElement('a');
        card.href = `/history/${session.id}`;
        card.className = 'session-card';

        const date = new Date(session.timestamp).toLocaleDateString('en-US', {
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
        });

        const preview =
          session.shapedPrompt.slice(0, 120) + (session.shapedPrompt.length > 120 ? '...' : '');

        let outcomeHtml = '';
        if (session.outcome) {
          outcomeHtml = `<span class="session-outcome ${session.outcome}">${outcomeLabels[session.outcome]}</span>`;
        }

        card.innerHTML = `
          <div class="session-card-header">
            <span class="session-mode" style="background: ${modeColors[session.mode]}">${session.mode}</span>
            <span class="session-date">${date}</span>
            ${outcomeHtml}
          </div>
          <p class="session-preview">${preview}</p>
          <p class="session-cost">${session.cost > 0 ? `$${session.cost.toFixed(4)}` : 'Free (in-browser)'}</p>
        `;

        listEl.appendChild(card);
      });
    }

    // Filter buttons
    document.querySelectorAll('.filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        currentFilter = btn.getAttribute('data-filter') || 'all';
        renderSessions();
      });
    });

    // Search
    searchInput.addEventListener('input', () => {
      searchQuery = searchInput.value;
      renderSessions();
    });

    // Load sessions
    listSessions().then((sessions) => {
      allSessions = sessions;
      renderSessions();
    });
  </script>
</AppShell>
