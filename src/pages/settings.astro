---
import AppShell from '../layouts/AppShell.astro';

const user = (Astro.locals as any).user;
const searchParams = Astro.url.searchParams;
const openrouterStatus = searchParams.get('openrouter');
const errorParam = searchParams.get('error');
---

<AppShell title="Settings">
  <h1>Settings</h1>

  {!user ? (
    <section class="section">
      <p>You need to <a href="/login">log in</a> or <a href="/signup">create an account</a> to access settings.</p>
    </section>
  ) : (
    <>
      <section class="section">
        <h2>Account</h2>
        <p class="detail">Signed in as <strong>{user.email}</strong></p>

        <button id="logout-btn" class="btn btn-secondary">Log out</button>
      </section>

      <section class="section">
        <h2>Change password</h2>
        <form id="password-form" class="form">
          <div class="field">
            <label for="currentPassword">Current password</label>
            <input type="password" id="currentPassword" name="currentPassword" required autocomplete="current-password" />
          </div>
          <div class="field">
            <label for="newPassword">New password</label>
            <input type="password" id="newPassword" name="newPassword" required minlength="8" autocomplete="new-password" />
            <span class="hint">At least 8 characters</span>
          </div>
          <div id="password-error" class="error" hidden></div>
          <div id="password-success" class="success" hidden></div>
          <button type="submit" class="btn">Update password</button>
        </form>
      </section>

      <section class="section">
        <h2>AI Budget (OpenRouter)</h2>
        <p class="detail">Connect your OpenRouter account to use cloud models. You control your own spending.</p>

        {openrouterStatus === 'connected' && (
          <div class="success">OpenRouter connected successfully.</div>
        )}
        {errorParam && (
          <div class="error">There was a problem connecting to OpenRouter. Please try again.</div>
        )}

        <div id="openrouter-status">
          <p class="detail">Checking connection...</p>
        </div>
      </section>

      <section class="section danger-zone">
        <h2>Danger zone</h2>
        <p class="detail">Permanently delete your account and all associated data.</p>
        <button id="delete-btn" class="btn btn-danger">Delete account</button>
      </section>
    </>
  )}

  <style>
    h1 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
    }

    .section {
      margin-bottom: 2rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid #e5e5e5;
    }

    .section:last-child {
      border-bottom: none;
    }

    h2 {
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .detail {
      color: #666;
      font-size: 0.9rem;
      margin-bottom: 0.75rem;
    }

    .form {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      max-width: 24rem;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    label {
      font-size: 0.875rem;
      font-weight: 500;
    }

    input {
      padding: 0.5rem 0.75rem;
      border: 1px solid #d4d4d4;
      border-radius: 0.375rem;
      font-size: 1rem;
      font-family: inherit;
    }

    input:focus {
      outline: 2px solid #2563eb;
      outline-offset: 1px;
    }

    .hint {
      font-size: 0.75rem;
      color: #888;
    }

    .error {
      padding: 0.5rem 0.75rem;
      background: #fef2f2;
      border: 1px solid #fecaca;
      border-radius: 0.375rem;
      color: #dc2626;
      font-size: 0.875rem;
    }

    .success {
      padding: 0.5rem 0.75rem;
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-radius: 0.375rem;
      color: #16a34a;
      font-size: 0.875rem;
    }

    .btn {
      padding: 0.5rem 1rem;
      background: #1a1a1a;
      color: #fff;
      border: none;
      border-radius: 0.375rem;
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      font-family: inherit;
      width: fit-content;
    }

    .btn:hover {
      background: #333;
    }

    .btn-secondary {
      background: #fff;
      color: #1a1a1a;
      border: 1px solid #d4d4d4;
    }

    .btn-secondary:hover {
      background: #f5f5f5;
    }

    .btn-danger {
      background: #dc2626;
    }

    .btn-danger:hover {
      background: #b91c1c;
    }

    .btn-connect {
      background: #2563eb;
    }

    .btn-connect:hover {
      background: #1d4ed8;
    }

    .btn-disconnect {
      background: #fff;
      color: #dc2626;
      border: 1px solid #fecaca;
    }

    .btn-disconnect:hover {
      background: #fef2f2;
    }

    .danger-zone {
      border-bottom: none;
    }

    .budget-info {
      font-size: 0.875rem;
      color: #666;
      margin-bottom: 0.75rem;
    }
  </style>

  <script>
    // Logout
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/login';
    });

    // Change password
    const pwForm = document.getElementById('password-form') as HTMLFormElement | null;
    pwForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorEl = document.getElementById('password-error') as HTMLDivElement;
      const successEl = document.getElementById('password-success') as HTMLDivElement;
      errorEl.hidden = true;
      successEl.hidden = true;

      const currentPassword = (pwForm.querySelector('#currentPassword') as HTMLInputElement).value;
      const newPassword = (pwForm.querySelector('#newPassword') as HTMLInputElement).value;

      const res = await fetch('/api/auth/password', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ currentPassword, newPassword }),
      });

      const data = await res.json();
      if (!res.ok) {
        errorEl.textContent = data.error || 'Something went wrong';
        errorEl.hidden = false;
      } else {
        successEl.textContent = 'Password updated.';
        successEl.hidden = false;
        pwForm.reset();
      }
    });

    // Delete account
    document.getElementById('delete-btn')?.addEventListener('click', async () => {
      if (!confirm('Are you sure you want to delete your account? This cannot be undone.')) return;
      const res = await fetch('/api/auth/account', { method: 'DELETE' });
      if (res.ok) {
        window.location.href = '/signup';
      }
    });

    // OpenRouter status
    async function loadOpenRouterStatus() {
      const container = document.getElementById('openrouter-status');
      if (!container) return;

      try {
        const res = await fetch('/api/auth/openrouter/status');
        const data = await res.json();

        if (data.data?.connected) {
          let budgetHtml = '';
          if (data.data.budget) {
            const b = data.data.budget;
            const limitStr = b.limit != null ? `$${(b.limit / 100).toFixed(2)}` : 'No limit set';
            const usageStr = `$${(b.usage / 100).toFixed(2)}`;
            const remainStr = b.remaining != null ? `$${(b.remaining / 100).toFixed(2)}` : 'N/A';
            budgetHtml = `<p class="budget-info">Budget: ${limitStr} | Used: ${usageStr} | Remaining: ${remainStr}</p>`;
          }
          container.innerHTML = `
            <p class="detail" style="color: #16a34a; font-weight: 500;">Connected to OpenRouter</p>
            ${budgetHtml}
            <button id="disconnect-openrouter" class="btn btn-disconnect">Disconnect</button>
          `;

          document.getElementById('disconnect-openrouter')?.addEventListener('click', async () => {
            if (!confirm('Disconnect your OpenRouter account?')) return;
            const r = await fetch('/api/auth/openrouter/disconnect', { method: 'POST' });
            if (r.ok) window.location.reload();
          });
        } else {
          const callbackUrl = encodeURIComponent(window.location.origin + '/api/auth/openrouter/callback');
          const connectUrl = `https://openrouter.ai/auth?callback_url=${callbackUrl}&limit=500&usage_limit_type=monthly`;
          container.innerHTML = `
            <p class="detail">Not connected.</p>
            <a href="${connectUrl}" class="btn btn-connect" style="display:inline-block; text-decoration:none; color:#fff;">Connect your AI budget</a>
          `;
        }
      } catch {
        container.innerHTML = '<p class="detail">Could not check OpenRouter status.</p>';
      }
    }

    loadOpenRouterStatus();
  </script>
</AppShell>
