---
import AppShell from '../layouts/AppShell.astro';
---

<AppShell title="Dashboard">
  <div class="dashboard">
    <div class="dashboard-header">
      <h1>Usage Dashboard</h1>
      <div class="time-filters" id="time-filters">
        <button class="filter-btn active" data-range="week">This week</button>
        <button class="filter-btn" data-range="month">This month</button>
        <button class="filter-btn" data-range="all">All time</button>
      </div>
    </div>

    <div class="stats-grid" id="stats-grid">
      <div class="stat-card">
        <span class="stat-label">Total sessions</span>
        <span class="stat-value" id="stat-total">0</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Total cost</span>
        <span class="stat-value" id="stat-cost">$0.00</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Energy used</span>
        <span class="stat-value" id="stat-energy">0 Wh</span>
      </div>
      <div class="stat-card highlight">
        <span class="stat-label">Energy saved</span>
        <span class="stat-value" id="stat-saved">0 Wh</span>
        <span class="stat-hint" id="stat-saved-hint">vs sending everything to GPT-4</span>
      </div>
    </div>

    <div class="charts-row">
      <div class="chart-card">
        <h2>Sessions by mode</h2>
        <div class="bar-chart" id="chart-modes">
          <div class="bar-row">
            <span class="bar-label">Brainstorm</span>
            <div class="bar-track"><div class="bar-fill brainstorm" id="bar-brainstorm" style="width: 0%"></div></div>
            <span class="bar-count" id="count-brainstorm">0</span>
          </div>
          <div class="bar-row">
            <span class="bar-label">Execute</span>
            <div class="bar-track"><div class="bar-fill execute" id="bar-execute" style="width: 0%"></div></div>
            <span class="bar-count" id="count-execute">0</span>
          </div>
          <div class="bar-row">
            <span class="bar-label">Refine</span>
            <div class="bar-track"><div class="bar-fill refine" id="bar-refine" style="width: 0%"></div></div>
            <span class="bar-count" id="count-refine">0</span>
          </div>
        </div>
      </div>

      <div class="chart-card">
        <h2>Model usage</h2>
        <div id="chart-models" class="model-list">
          <p class="empty-state">No sessions yet</p>
        </div>
      </div>
    </div>

    <div class="chart-card full-width">
      <h2>Sessions over time</h2>
      <div class="timeline" id="chart-timeline">
        <p class="empty-state">No sessions yet</p>
      </div>
    </div>

    <div class="chart-card full-width">
      <h2>Outcomes</h2>
      <div class="outcomes-row" id="chart-outcomes">
        <div class="outcome-block">
          <span class="outcome-count" id="outcome-yes">0</span>
          <span class="outcome-label outcome-yes">Got what I needed</span>
        </div>
        <div class="outcome-block">
          <span class="outcome-count" id="outcome-partial">0</span>
          <span class="outcome-label outcome-partial">Partially</span>
        </div>
        <div class="outcome-block">
          <span class="outcome-count" id="outcome-no">0</span>
          <span class="outcome-label outcome-no">No</span>
        </div>
        <div class="outcome-block">
          <span class="outcome-count" id="outcome-none">0</span>
          <span class="outcome-label outcome-none">Not rated</span>
        </div>
      </div>
    </div>
  </div>

  <style>
    .dashboard {
      max-width: 56rem;
      margin: 0 auto;
    }

    .dashboard-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .dashboard-header h1 {
      font-size: 1.5rem;
      font-weight: 700;
    }

    .time-filters {
      display: flex;
      gap: 0.25rem;
      background: #f0f0f0;
      border-radius: 0.5rem;
      padding: 0.2rem;
    }

    .filter-btn {
      padding: 0.35rem 0.75rem;
      border: none;
      background: transparent;
      font-size: 0.8rem;
      font-weight: 500;
      color: #666;
      border-radius: 0.35rem;
      cursor: pointer;
    }

    .filter-btn.active {
      background: #fff;
      color: #1a1a1a;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .stat-card {
      background: #fff;
      border: 1px solid #e5e5e5;
      border-radius: 0.75rem;
      padding: 1rem;
    }

    .stat-card.highlight {
      background: #f0fdf4;
      border-color: #bbf7d0;
    }

    .stat-label {
      display: block;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #999;
      font-weight: 600;
      margin-bottom: 0.25rem;
    }

    .stat-value {
      display: block;
      font-size: 1.5rem;
      font-weight: 700;
      color: #1a1a1a;
      font-variant-numeric: tabular-nums;
    }

    .stat-hint {
      display: block;
      font-size: 0.7rem;
      color: #999;
      margin-top: 0.25rem;
    }

    .charts-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .chart-card {
      background: #fff;
      border: 1px solid #e5e5e5;
      border-radius: 0.75rem;
      padding: 1.25rem;
    }

    .chart-card.full-width {
      margin-bottom: 1rem;
    }

    .chart-card h2 {
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #999;
      margin-bottom: 1rem;
    }

    .bar-chart {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .bar-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .bar-label {
      font-size: 0.8rem;
      font-weight: 500;
      min-width: 5.5rem;
      color: #333;
    }

    .bar-track {
      flex: 1;
      height: 1.25rem;
      background: #f5f5f5;
      border-radius: 0.5rem;
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      border-radius: 0.5rem;
      transition: width 0.4s ease;
    }

    .bar-fill.brainstorm { background: #2563eb; }
    .bar-fill.execute { background: #059669; }
    .bar-fill.refine { background: #9333ea; }

    .bar-count {
      font-size: 0.8rem;
      font-weight: 600;
      min-width: 1.5rem;
      text-align: right;
      color: #666;
    }

    .model-list {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .model-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.8rem;
      padding: 0.35rem 0;
      border-bottom: 1px solid #f5f5f5;
    }

    .model-row:last-child { border-bottom: none; }

    .model-name { color: #333; font-weight: 500; }
    .model-count { color: #999; font-weight: 600; }

    .timeline {
      display: flex;
      align-items: flex-end;
      gap: 2px;
      height: 6rem;
      padding-top: 0.5rem;
    }

    .timeline-bar {
      flex: 1;
      background: #2563eb;
      border-radius: 2px 2px 0 0;
      min-width: 4px;
      transition: height 0.3s ease;
      position: relative;
    }

    .timeline-bar:hover {
      opacity: 0.8;
    }

    .outcomes-row {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .outcome-block {
      text-align: center;
      flex: 1;
      min-width: 5rem;
    }

    .outcome-count {
      display: block;
      font-size: 1.75rem;
      font-weight: 700;
      color: #1a1a1a;
    }

    .outcome-label {
      font-size: 0.75rem;
      font-weight: 500;
    }

    .outcome-yes { color: #059669; }
    .outcome-partial { color: #d97706; }
    .outcome-no { color: #dc2626; }
    .outcome-none { color: #999; }

    .empty-state {
      color: #ccc;
      font-size: 0.85rem;
      text-align: center;
      padding: 1rem;
    }

    @media (max-width: 640px) {
      .charts-row {
        grid-template-columns: 1fr;
      }

      .stats-grid {
        grid-template-columns: 1fr 1fr;
      }

      .outcomes-row {
        gap: 1rem;
      }
    }
  </style>

  <script>
    import { listSessions } from '../lib/session-store';
    import { getEnergyData } from '../lib/energy-data';
    import type { Session, Mode } from '../lib/types';

    // GPT-4 energy per query for "saved" comparison
    const GPT4_KWH = 0.01;

    type TimeRange = 'week' | 'month' | 'all';
    let currentRange: TimeRange = 'week';

    function getStartTimestamp(range: TimeRange): number {
      const now = Date.now();
      if (range === 'week') return now - 7 * 24 * 60 * 60 * 1000;
      if (range === 'month') return now - 30 * 24 * 60 * 60 * 1000;
      return 0;
    }

    function filterSessions(sessions: Session[], range: TimeRange): Session[] {
      const start = getStartTimestamp(range);
      return sessions.filter((s) => s.timestamp >= start);
    }

    function formatEnergy(kwh: number): string {
      if (kwh === 0) return '0 Wh';
      const wh = kwh * 1000;
      if (wh < 1) return `${(wh * 1000).toFixed(1)} mWh`;
      if (wh < 1000) return `${wh.toFixed(1)} Wh`;
      return `${kwh.toFixed(2)} kWh`;
    }

    function formatCost(cost: number): string {
      if (cost === 0) return '$0.00';
      if (cost < 0.01) return `$${cost.toFixed(4)}`;
      return `$${cost.toFixed(2)}`;
    }

    function render(sessions: Session[]) {
      const filtered = filterSessions(sessions, currentRange);

      // Stats
      document.getElementById('stat-total')!.textContent = String(filtered.length);
      const totalCost = filtered.reduce((sum, s) => sum + s.cost, 0);
      document.getElementById('stat-cost')!.textContent = formatCost(totalCost);

      const totalEnergy = filtered.reduce((sum, s) => sum + s.energyEstimate, 0);
      document.getElementById('stat-energy')!.textContent = formatEnergy(totalEnergy);

      // Energy saved: if every session used GPT-4 instead
      const gpt4Energy = filtered.length * GPT4_KWH;
      const saved = gpt4Energy - totalEnergy;
      document.getElementById('stat-saved')!.textContent = formatEnergy(Math.max(0, saved));

      // Mode bars
      const modeCounts: Record<Mode, number> = { brainstorm: 0, execute: 0, refine: 0 };
      for (const s of filtered) modeCounts[s.mode]++;
      const maxMode = Math.max(1, ...Object.values(modeCounts));

      for (const mode of ['brainstorm', 'execute', 'refine'] as Mode[]) {
        const bar = document.getElementById(`bar-${mode}`) as HTMLElement;
        const count = document.getElementById(`count-${mode}`)!;
        bar.style.width = `${(modeCounts[mode] / maxMode) * 100}%`;
        count.textContent = String(modeCounts[mode]);
      }

      // Model usage
      const modelCounts = new Map<string, number>();
      for (const s of filtered) {
        const name = s.modelUsed === 'browser-local' ? 'In-browser (Phi-3.5)' : s.modelUsed.split('/').pop() || s.modelUsed;
        modelCounts.set(name, (modelCounts.get(name) || 0) + 1);
      }

      const modelsEl = document.getElementById('chart-models')!;
      if (modelCounts.size === 0) {
        modelsEl.innerHTML = '<p class="empty-state">No sessions yet</p>';
      } else {
        const sorted = [...modelCounts.entries()].sort((a, b) => b[1] - a[1]);
        modelsEl.innerHTML = sorted
          .map(([name, count]) => `<div class="model-row"><span class="model-name">${name}</span><span class="model-count">${count}</span></div>`)
          .join('');
      }

      // Timeline (group by day)
      const timelineEl = document.getElementById('chart-timeline')!;
      if (filtered.length === 0) {
        timelineEl.innerHTML = '<p class="empty-state">No sessions yet</p>';
      } else {
        const dayCounts = new Map<string, number>();
        for (const s of filtered) {
          const day = new Date(s.timestamp).toISOString().slice(0, 10);
          dayCounts.set(day, (dayCounts.get(day) || 0) + 1);
        }

        // Fill in missing days
        const start = getStartTimestamp(currentRange);
        const startDate = currentRange === 'all' && filtered.length > 0
          ? new Date(Math.min(...filtered.map(s => s.timestamp)))
          : new Date(start);
        const today = new Date();
        const days: [string, number][] = [];
        const d = new Date(startDate);
        d.setHours(0, 0, 0, 0);
        while (d <= today) {
          const key = d.toISOString().slice(0, 10);
          days.push([key, dayCounts.get(key) || 0]);
          d.setDate(d.getDate() + 1);
        }

        const maxCount = Math.max(1, ...days.map(([, c]) => c));
        timelineEl.innerHTML = days
          .map(([day, count]) => {
            const height = count > 0 ? Math.max(4, (count / maxCount) * 100) : 0;
            return `<div class="timeline-bar" style="height: ${height}%" title="${day}: ${count} session${count !== 1 ? 's' : ''}"></div>`;
          })
          .join('');
      }

      // Outcomes
      let outcomeYes = 0, outcomePartial = 0, outcomeNo = 0, outcomeNone = 0;
      for (const s of filtered) {
        if (s.outcome === 'yes') outcomeYes++;
        else if (s.outcome === 'partially') outcomePartial++;
        else if (s.outcome === 'no') outcomeNo++;
        else outcomeNone++;
      }
      document.getElementById('outcome-yes')!.textContent = String(outcomeYes);
      document.getElementById('outcome-partial')!.textContent = String(outcomePartial);
      document.getElementById('outcome-no')!.textContent = String(outcomeNo);
      document.getElementById('outcome-none')!.textContent = String(outcomeNone);
    }

    // Time filter buttons
    const filterBtns = document.querySelectorAll('.filter-btn');
    filterBtns.forEach((btn) => {
      btn.addEventListener('click', async () => {
        filterBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        currentRange = (btn as HTMLElement).dataset.range as TimeRange;
        const sessions = await listSessions();
        render(sessions);
      });
    });

    // Initial render
    listSessions().then(render);
  </script>
</AppShell>
