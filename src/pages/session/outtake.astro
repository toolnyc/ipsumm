---
import AppShell from '../../layouts/AppShell.astro';
---

<AppShell title="How did it go?">
  <div class="outtake" id="outtake">
    <h1>How did it go?</h1>

    <div class="criteria" id="criteria">
      <p class="criteria-label">You said success looked like:</p>
      <blockquote id="success-text"></blockquote>
    </div>

    <div class="outcome-question">
      <p>Did you get what you needed?</p>
      <div class="outcome-options">
        <button class="outcome-btn" data-outcome="yes">Yes</button>
        <button class="outcome-btn" data-outcome="partially">Partially</button>
        <button class="outcome-btn" data-outcome="no">No</button>
      </div>
    </div>

    <div class="reflection-area" id="reflection-area" style="display: none;">
      <label for="reflection">Any thoughts on the session? (optional)</label>
      <textarea id="reflection" placeholder="What would you do differently next time?" rows={3}></textarea>
      <button id="btn-save" class="btn btn-primary">Save and finish</button>
      <button id="btn-skip" class="btn btn-secondary">Skip</button>
    </div>
  </div>

  <style>
    .outtake {
      max-width: 32rem;
      margin: 0 auto;
      text-align: center;
    }

    h1 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
    }

    .criteria {
      margin-bottom: 2rem;
    }

    .criteria-label {
      font-size: 0.85rem;
      color: #999;
      margin-bottom: 0.5rem;
    }

    blockquote {
      font-size: 1rem;
      color: #333;
      font-style: italic;
      padding: 0.75rem 1rem;
      background: #f9f9f9;
      border-left: 3px solid #ddd;
      border-radius: 0 0.5rem 0.5rem 0;
      text-align: left;
    }

    .outcome-question p {
      font-size: 1.1rem;
      font-weight: 500;
      margin-bottom: 1rem;
    }

    .outcome-options {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
    }

    .outcome-btn {
      padding: 0.6rem 1.5rem;
      border: 1px solid #ddd;
      border-radius: 0.5rem;
      background: #fff;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s;
    }

    .outcome-btn:hover {
      border-color: #888;
    }

    .outcome-btn.selected {
      background: #1a1a1a;
      color: #fff;
      border-color: #1a1a1a;
    }

    .reflection-area {
      margin-top: 2rem;
      text-align: left;
    }

    .reflection-area label {
      display: block;
      font-size: 0.9rem;
      font-weight: 500;
      margin-bottom: 0.5rem;
    }

    .reflection-area textarea {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid #ddd;
      border-radius: 0.5rem;
      font-family: inherit;
      font-size: 0.9rem;
      resize: vertical;
      margin-bottom: 1rem;
    }

    .reflection-area textarea:focus {
      outline: none;
      border-color: #888;
    }

    .btn {
      padding: 0.6rem 1.5rem;
      border: none;
      border-radius: 0.5rem;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
    }

    .btn-primary {
      background: #1a1a1a;
      color: #fff;
      margin-right: 0.5rem;
    }

    .btn-primary:hover {
      opacity: 0.85;
    }

    .btn-secondary {
      background: #f0f0f0;
      color: #333;
    }

    .btn-secondary:hover {
      background: #e5e5e5;
    }
  </style>

  <script>
    import { updateSession } from '../../lib/session-store';
    import type { Outcome } from '../../lib/types';

    const params = new URLSearchParams(window.location.search);
    const sessionId = params.get('session');
    const mode = params.get('mode') || 'brainstorm';

    // Show success criteria from intake
    const rawStr = sessionStorage.getItem(`ipsumm-raw-${mode}`);
    const successText = document.getElementById('success-text')!;
    const criteriaEl = document.getElementById('criteria')!;

    if (rawStr) {
      const raw = JSON.parse(rawStr);
      const criteria = raw.output || raw.success || raw.change || '';
      if (criteria) {
        successText.textContent = criteria;
      } else {
        criteriaEl.style.display = 'none';
      }
    } else {
      criteriaEl.style.display = 'none';
    }

    // Outcome selection
    let selectedOutcome: Outcome | null = null;
    const buttons = document.querySelectorAll('.outcome-btn');
    const reflectionArea = document.getElementById('reflection-area')!;

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('selected'));
        btn.classList.add('selected');
        selectedOutcome = btn.getAttribute('data-outcome') as Outcome;
        reflectionArea.style.display = 'block';
      });
    });

    async function saveAndFinish(reflection: string | null) {
      if (sessionId && selectedOutcome) {
        await updateSession(sessionId, {
          outcome: selectedOutcome,
          reflection,
        });
      }

      // Clean up
      sessionStorage.removeItem(`ipsumm-intake-${mode}`);
      sessionStorage.removeItem(`ipsumm-shaped-${mode}`);
      sessionStorage.removeItem(`ipsumm-raw-${mode}`);

      window.location.href = '/history';
    }

    document.getElementById('btn-save')!.addEventListener('click', () => {
      const reflection = (document.getElementById('reflection') as HTMLTextAreaElement).value.trim();
      saveAndFinish(reflection || null);
    });

    document.getElementById('btn-skip')!.addEventListener('click', () => {
      saveAndFinish(null);
    });
  </script>
</AppShell>
