---
import AppShell from '../../layouts/AppShell.astro';
---

<AppShell title="Session">
  <div class="session" id="session-container">
    <div class="session-header">
      <span class="mode-badge" id="mode-badge"></span>
      <span class="model-info" id="model-info"></span>
      <span class="energy-badge" id="energy-badge"></span>
      <span class="cost-display" id="cost-display">$0.00</span>
    </div>

    <div class="messages" id="messages"></div>

    <div class="input-area" id="input-area">
      <textarea
        id="user-input"
        placeholder="Send a follow-up message..."
        rows={2}
      ></textarea>
      <button id="btn-send" class="btn-send">Send</button>
    </div>

    <div class="session-actions">
      <button id="btn-end" class="btn btn-secondary">End session</button>
    </div>

    <div id="model-loading" class="model-loading" style="display: none;">
      <p id="loading-text">Loading model...</p>
      <div class="progress-bar">
        <div class="progress-fill" id="progress-fill"></div>
      </div>
    </div>
  </div>

  <style>
    .session {
      max-width: 48rem;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      min-height: calc(100dvh - 10rem);
    }

    .session-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid #e5e5e5;
      margin-bottom: 1.5rem;
    }

    .mode-badge {
      color: #fff;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 0.2rem 0.6rem;
      border-radius: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .model-info {
      font-size: 0.8rem;
      color: #999;
    }

    .energy-badge {
      font-size: 0.7rem;
      font-weight: 600;
      padding: 0.15rem 0.5rem;
      border-radius: 0.75rem;
      display: none;
    }

    .energy-badge.rating-A { background: #dcfce7; color: #166534; }
    .energy-badge.rating-B { background: #dbeafe; color: #1e40af; }
    .energy-badge.rating-C { background: #fef9c3; color: #854d0e; }
    .energy-badge.rating-D { background: #fed7aa; color: #9a3412; }
    .energy-badge.rating-E { background: #fecaca; color: #991b1b; }
    .energy-badge.rating-local { background: #f0fdf4; color: #166534; }

    .cost-display {
      margin-left: auto;
      font-size: 0.8rem;
      color: #999;
      font-variant-numeric: tabular-nums;
    }

    .messages {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      padding-bottom: 1.5rem;
    }

    .message {
      padding: 0.75rem 1rem;
      border-radius: 0.75rem;
      font-size: 0.9rem;
      line-height: 1.6;
      max-width: 85%;
      white-space: pre-wrap;
    }

    .message.user {
      background: #f0f0f0;
      align-self: flex-end;
      color: #1a1a1a;
    }

    .message.assistant {
      background: #fff;
      border: 1px solid #e5e5e5;
      align-self: flex-start;
    }

    .message.system-msg {
      background: #fef3cd;
      align-self: center;
      text-align: center;
      font-size: 0.8rem;
      color: #856404;
    }

    .thinking {
      color: #999;
      font-style: italic;
      padding: 0.5rem 1rem;
    }

    .input-area {
      display: flex;
      gap: 0.5rem;
      padding-top: 1rem;
      border-top: 1px solid #e5e5e5;
    }

    .input-area textarea {
      flex: 1;
      padding: 0.6rem 0.75rem;
      border: 1px solid #ddd;
      border-radius: 0.5rem;
      font-family: inherit;
      font-size: 0.9rem;
      resize: none;
    }

    .input-area textarea:focus {
      outline: none;
      border-color: #888;
    }

    .btn-send {
      padding: 0.6rem 1.25rem;
      background: #1a1a1a;
      color: #fff;
      border: none;
      border-radius: 0.5rem;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
    }

    .btn-send:hover {
      opacity: 0.85;
    }

    .btn-send:disabled {
      opacity: 0.4;
      cursor: default;
    }

    .session-actions {
      display: flex;
      justify-content: flex-end;
      padding-top: 1rem;
    }

    .btn {
      padding: 0.5rem 1.25rem;
      border: none;
      border-radius: 0.5rem;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
    }

    .btn-secondary {
      background: #f0f0f0;
      color: #333;
    }

    .btn-secondary:hover {
      background: #e5e5e5;
    }

    .model-loading {
      text-align: center;
      padding: 2rem;
    }

    .model-loading p {
      font-size: 0.9rem;
      color: #666;
      margin-bottom: 1rem;
    }

    .progress-bar {
      width: 100%;
      max-width: 20rem;
      height: 0.5rem;
      background: #e5e5e5;
      border-radius: 1rem;
      margin: 0 auto;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: #2563eb;
      border-radius: 1rem;
      transition: width 0.3s;
      width: 0%;
    }

    @media (max-width: 640px) {
      .session-header {
        flex-wrap: wrap;
        gap: 0.5rem;
      }
    }
  </style>

  <script>
    import { generateWithHistory, loadModel, isLoaded, isSupported } from '../../lib/browser-llm';
    import { getSystemPrompt, buildSystemPrompt } from '../../lib/system-prompts';
    import { createSession, updateSession } from '../../lib/session-store';
    import { getEnergyData } from '../../lib/energy-data';
    import { selectModel } from '../../lib/routing';
    import { calculateCost } from '../../lib/openrouter';
    import type { Mode, Message, SessionTokenUsage } from '../../lib/types';

    const modeColors: Record<Mode, string> = {
      brainstorm: '#2563eb',
      execute: '#059669',
      refine: '#9333ea',
    };

    // Get session params from URL and sessionStorage
    const pathParts = window.location.pathname.split('/');
    const sessionId = pathParts[pathParts.length - 1];
    const params = new URLSearchParams(window.location.search);
    const mode = (params.get('mode') || 'brainstorm') as Mode;
    const shapedPrompt = sessionStorage.getItem(`ipsumm-shaped-${mode}`) || '';
    const rawInputStr = sessionStorage.getItem(`ipsumm-raw-${mode}`) || '{}';
    const rawInput = JSON.parse(rawInputStr);

    const conversation: Message[] = [];
    let isGenerating = false;
    let useCloud = false;
    let cloudModelId = '';
    let cloudTemperature = 0.7;
    let totalCost = 0;
    let totalTokens: SessionTokenUsage = { prompt_tokens: 0, completion_tokens: 0, total_tokens: 0 };

    // DOM
    const badge = document.getElementById('mode-badge')!;
    badge.textContent = mode;
    badge.style.background = modeColors[mode];

    const modelInfo = document.getElementById('model-info')!;
    const energyBadge = document.getElementById('energy-badge')!;
    const costDisplay = document.getElementById('cost-display')!;
    const messagesEl = document.getElementById('messages')!;
    const userInput = document.getElementById('user-input') as HTMLTextAreaElement;
    const btnSend = document.getElementById('btn-send') as HTMLButtonElement;
    const btnEnd = document.getElementById('btn-end') as HTMLButtonElement;
    const loadingEl = document.getElementById('model-loading')!;
    const loadingText = document.getElementById('loading-text')!;
    const progressFill = document.getElementById('progress-fill')!;

    function updateCostDisplay() {
      costDisplay.textContent = totalCost < 0.01
        ? `$${totalCost.toFixed(4)}`
        : `$${totalCost.toFixed(2)}`;
    }

    function showEnergyBadge(rating: string, analogy: string) {
      energyBadge.textContent = rating === 'local' ? 'On-device' : `Energy: ${rating}`;
      energyBadge.className = `energy-badge rating-${rating}`;
      energyBadge.title = analogy;
      energyBadge.style.display = 'inline-block';
    }

    function addMessage(role: 'user' | 'assistant' | 'system', content: string): HTMLElement {
      const div = document.createElement('div');
      div.className = `message ${role === 'system' ? 'system-msg' : role}`;
      div.textContent = content;
      messagesEl.appendChild(div);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return div;
    }

    // Check if user has OpenRouter connected
    async function checkCloudAvailability(): Promise<boolean> {
      try {
        const res = await fetch('/api/auth/openrouter/status');
        if (!res.ok) return false;
        const data = await res.json();
        return data.connected === true;
      } catch {
        return false;
      }
    }

    // Stream from cloud via /api/chat
    async function cloudGenerate(messages: Message[]): Promise<string> {
      isGenerating = true;
      btnSend.disabled = true;
      const assistantDiv = addMessage('assistant', '');
      let fullResponse = '';

      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: cloudModelId,
          messages,
          temperature: cloudTemperature,
        }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Request failed' }));
        const msg = (err as any).error || 'Cloud model error';
        assistantDiv.textContent = msg;
        assistantDiv.className = 'message system-msg';
        isGenerating = false;
        btnSend.disabled = false;
        return '';
      }

      // Parse SSE stream
      const reader = res.body!.getReader();
      const decoder = new TextDecoder();
      let buffer = '';
      let chunkUsage: { prompt_tokens?: number; completion_tokens?: number; total_tokens?: number } | null = null;

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop()!;

        for (const line of lines) {
          const trimmed = line.trim();
          if (!trimmed || trimmed === 'data: [DONE]') continue;
          if (!trimmed.startsWith('data: ')) continue;

          try {
            const data = JSON.parse(trimmed.slice(6));
            const content = data.choices?.[0]?.delta?.content;
            if (content) {
              fullResponse += content;
              assistantDiv.textContent = fullResponse;
              messagesEl.scrollTop = messagesEl.scrollHeight;
            }
            if (data.usage) {
              chunkUsage = data.usage;
            }
          } catch {
            // skip malformed lines
          }
        }
      }

      // Update cost tracking
      if (chunkUsage) {
        const usage = {
          prompt_tokens: chunkUsage.prompt_tokens ?? 0,
          completion_tokens: chunkUsage.completion_tokens ?? 0,
          total_tokens: chunkUsage.total_tokens ?? 0,
        };
        totalTokens.prompt_tokens += usage.prompt_tokens;
        totalTokens.completion_tokens += usage.completion_tokens;
        totalTokens.total_tokens += usage.total_tokens;
        totalCost += calculateCost(cloudModelId, usage);
        updateCostDisplay();
      }

      conversation.push({ role: 'assistant', content: fullResponse });
      isGenerating = false;
      btnSend.disabled = false;
      return fullResponse;
    }

    // Browser LLM generate
    async function browserGenerate(): Promise<string> {
      isGenerating = true;
      btnSend.disabled = true;
      const assistantDiv = addMessage('assistant', '');
      let fullResponse = '';

      try {
        await generateWithHistory(conversation, (token) => {
          fullResponse += token;
          assistantDiv.textContent = fullResponse;
          messagesEl.scrollTop = messagesEl.scrollHeight;
        });
      } catch (err: any) {
        assistantDiv.textContent = `Error: ${err.message}`;
        assistantDiv.className = 'message system-msg';
      }

      conversation.push({ role: 'assistant', content: fullResponse });
      isGenerating = false;
      btnSend.disabled = false;
      return fullResponse;
    }

    async function sendMessage(text: string) {
      if (!text || isGenerating) return;
      conversation.push({ role: 'user', content: text });
      addMessage('user', text);

      if (useCloud) {
        await cloudGenerate(conversation);
      } else {
        await browserGenerate();
      }
    }

    async function startSession() {
      const hasCloud = await checkCloudAvailability();

      if (hasCloud) {
        // Use cloud model
        useCloud = true;
        const modelConfig = selectModel(mode);
        cloudModelId = modelConfig.modelId;
        cloudTemperature = modelConfig.temperature;

        const energy = getEnergyData(cloudModelId);
        modelInfo.textContent = `${modelConfig.displayName}`;
        if (energy.rating !== 'local') {
          showEnergyBadge(energy.rating, energy.analogy);
        }

        // Build system prompt and send shaped prompt
        const systemPrompt = buildSystemPrompt(mode);
        conversation.push({ role: 'system', content: systemPrompt });
        conversation.push({ role: 'user', content: shapedPrompt });
        addMessage('user', shapedPrompt);

        await cloudGenerate(conversation);
      } else {
        // Fall back to browser LLM
        useCloud = false;
        const energy = getEnergyData('browser-local');
        modelInfo.textContent = `In-browser (Phi-3.5 Mini)`;
        showEnergyBadge('local', energy.analogy);
        costDisplay.textContent = '$0.00';

        if (!isSupported()) {
          addMessage('system', 'Your browser does not support local AI. Connect OpenRouter in Settings for cloud models.');
          return;
        }

        if (!isLoaded()) {
          loadingEl.style.display = 'block';
          await loadModel((p) => {
            loadingText.textContent = p.text;
            progressFill.style.width = `${Math.round(p.progress * 100)}%`;
          });
          loadingEl.style.display = 'none';
        }

        const systemPrompt = buildSystemPrompt(mode);
        conversation.push({ role: 'system', content: systemPrompt });
        conversation.push({ role: 'user', content: shapedPrompt });
        addMessage('user', shapedPrompt);

        await browserGenerate();
      }
    }

    // Follow-up messages
    btnSend.addEventListener('click', () => {
      const text = userInput.value.trim();
      if (text) {
        userInput.value = '';
        sendMessage(text);
      }
    });

    userInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        const text = userInput.value.trim();
        if (text) {
          userInput.value = '';
          sendMessage(text);
        }
      }
    });

    // End session
    btnEnd.addEventListener('click', async () => {
      const modelUsed = useCloud ? cloudModelId : 'browser-local';
      const energy = getEnergyData(modelUsed);
      const energyEstimate = energy.rating === 'local' ? 0 : energy.kwhPerQuery;

      const session = await createSession({
        mode,
        timestamp: Date.now(),
        rawInput,
        shapedPrompt,
        conversation: conversation.filter((m) => m.role !== 'system'),
        modelUsed,
        cost: totalCost,
        tokenUsage: totalTokens,
        energyEstimate,
        outcome: null,
        reflection: null,
      });

      window.location.href = `/session/outtake?session=${session.id}&mode=${mode}`;
    });

    startSession();
  </script>
</AppShell>
