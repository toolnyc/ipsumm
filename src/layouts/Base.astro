---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="ipsumm — intentional AI usage" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — ipsumm</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        font-family: system-ui, -apple-system, sans-serif;
        line-height: 1.6;
        color: #1a1a1a;
        background: #fafafa;
      }

      body {
        min-height: 100dvh;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
